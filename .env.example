# Turso Database Configuration
# Get these from: https://turso.tech/app/databases
TURSO_DATABASE_URL=libsql://your-database-name.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# JWT Configuration
JWT_SECRET=your-very-secure-jwt-secret-min-32-characters
JWT_REFRESH_SECRET=another-very-secure-secret-min-32-characters

# Next.js Configuration
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Google OAuth (Optional - for social login)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub OAuth (Optional - for social login)
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Environment
NODE_ENV=production  # Set to 'development' for local development