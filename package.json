{
  "name": "valifi-fintech-platform",
  "version": "3.0.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node simple-server.js",
    "apprunner:build": "npm run build",
    "apprunner:install": "npm install --production=false",
    "aws:build": "npm run build",
    "aws:start": "node simple-server.js",
    "lint": "eslint .",
    "typecheck": "npx tsc --noEmit",
    "bun:dev": "bun run --watch bun-server.ts",
    "bun:start": "bun run bun-server.ts",
    "bun:build": "bun build ./bun-server.ts --outdir ./dist --target bun",
    "full-stack": "concurrently \"cross-env PORT=3001 node simple-server.js\" \"vite\"",
    "production:server": "cross-env NODE_ENV=production PORT=3001 node simple-server.js",
    "db:migrate": "psql $DATABASE_URL -f migrations/001-production-schema.sql && psql $DATABASE_URL -f migrations/002-fintech-schema.sql",
    "db:setup": "bun run scripts/setup-database.ts",
    "db:setup-rds": "bun run scripts/setup-rds-database.ts",
    "test:integration": "bun ts-node tests/integration-test.ts",
    "test:services": "bun run test:integration",
    "production:start": "NODE_ENV=production node simple-server.js",
    "production:build": "npm run build"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@libsql/client": "^0.3.5",
    "autoprefixer": "^10.4.14",
    "axios": "^1.5.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "i18next": "^25.4.2",
    "i18next-browser-languagedetector": "^8.2.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.456.0",
    "next": "^15.5.4",
    "otpauth": "^9.4.1",
    "pg": "^8.16.3",
    "postcss": "^8.5.6",
    "postcss-loader": "^8.2.0",
    "qrcode": "^1.5.4",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-hot-toast": "^2.4.1",
    "react-i18next": "^15.7.2",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "styled-jsx": "^5.1.7",
    "tailwindcss": "^3.3.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@babel/core": "^7.28.4",
    "@babel/preset-env": "^7.28.3",
    "@babel/preset-react": "^7.27.1",
    "@babel/preset-typescript": "^7.27.1",
    "@types/bcryptjs": "^2.4.2",
    "@types/bun": "^1.2.22",
    "@types/node": "^24.5.2",
    "@types/pg": "^8.10.9",
    "@types/qrcode": "^1.5.5",
    "@types/react": "18.3.24",
    "@types/react-dom": "^18.2.0",
    "@types/react-i18next": "^7.8.3",
    "@vitejs/plugin-react": "^5.0.3",
    "babel-loader": "^10.0.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.0.0",
    "css-loader": "^6.8.1",
    "eslint": "^8.42.0",
    "html-webpack-plugin": "^5.5.3",
    "style-loader": "^3.3.3",
    "ts-loader": "^9.5.0",
    "typescript": "^5.0.0",
    "vite": "^7.1.6",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
