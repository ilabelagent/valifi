# ============================================
# VALIFI BOT - RENDER DEPLOYMENT ENVIRONMENT
# ============================================
# Copy this file to .env.production and fill in your values
# These values will be set in Render Dashboard

# ============================================
# CORE CONFIGURATION
# ============================================

# Application URLs (Render will provide these)
NEXT_PUBLIC_APP_URL=https://your-app-name.onrender.com
NEXT_PUBLIC_API_URL=https://your-app-name.onrender.com/api
NODE_ENV=production
PORT=3000

# ============================================
# DATABASE (Choose one option)
# ============================================

# Option 1: Render PostgreSQL (Auto-configured)
# DATABASE_URL will be automatically set by Render when you add a PostgreSQL database

# Option 2: External PostgreSQL (e.g., Neon, Supabase)
DATABASE_URL=postgresql://username:password@host:5432/database?sslmode=require
POSTGRES_URL=postgresql://username:password@host:5432/database?sslmode=require
POSTGRES_PRISMA_URL=postgresql://username:password@host:5432/database?sslmode=require&pgbouncer=true
POSTGRES_URL_NON_POOLING=postgresql://username:password@host:5432/database?sslmode=require

# Option 3: Turso Database
TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# ============================================
# SECURITY KEYS (Generate these!)
# ============================================

# Generate with: openssl rand -hex 64
JWT_SECRET=generate-a-64-character-hex-string
JWT_REFRESH_SECRET=generate-another-64-character-hex-string

# Generate with: openssl rand -hex 32
NEXTAUTH_SECRET=generate-a-32-character-hex-string
ENCRYPTION_KEY=generate-a-32-character-hex-string
SESSION_SECRET=generate-a-32-character-hex-string

# ============================================
# REDIS/KV STORE (Optional)
# ============================================

# Upstash Redis
KV_URL=redis://default:password@redis-host.upstash.io:port
KV_REST_API_URL=https://redis-host.upstash.io
KV_REST_API_TOKEN=your-upstash-token
KV_REST_API_READ_ONLY_TOKEN=your-readonly-token

# ============================================
# AI SERVICES (Optional)
# ============================================

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# ============================================
# EMAIL SERVICE (Required for notifications)
# ============================================

# SMTP Configuration (Gmail, SendGrid, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
EMAIL_FROM=Valifi Bot <noreply@valifi.com>

# ============================================
# PAYMENT GATEWAY (Required for payments)
# ============================================

# Stripe
STRIPE_PUBLIC_KEY=pk_live_your-stripe-public-key
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# ============================================
# MARKET DATA APIS (Required for trading)
# ============================================

# Alpha Vantage (Free tier available)
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-key

# CoinMarketCap
COINMARKETCAP_API_KEY=your-coinmarketcap-key

# ============================================
# BOT CONFIGURATION
# ============================================

BOT_RATE_LIMIT=100
BOT_EVOLUTION_ENABLED=true
BOT_MAX_CONCURRENT=10
BOT_DEFAULT_TIMEOUT=30000

# ============================================
# SECURITY SETTINGS
# ============================================

BCRYPT_ROUNDS=10
SESSION_TIMEOUT=3600000
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION=900000
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# FEATURE FLAGS
# ============================================

ENABLE_DEMO_MODE=false
ENABLE_TRADING_BOTS=true
ENABLE_DEFI=true
ENABLE_P2P=true
ENABLE_STAKING=true
ENABLE_NFT=true
ENABLE_AI_ASSISTANT=true
ENABLE_2FA=true
ENABLE_KYC=false
REQUIRE_EMAIL_VERIFICATION=true

# ============================================
# LIVE FEATURES
# ============================================

NEXT_PUBLIC_LIVE_PATCH=true
NEXT_PUBLIC_BOT_EVOLUTION=true

# ============================================
# MONITORING (Optional but recommended)
# ============================================

# Sentry Error Tracking
SENTRY_DSN=https://your-key@sentry.io/project-id
SENTRY_ENVIRONMENT=production

# Logging
LOG_LEVEL=info
ENABLE_LOGGING=true
ENABLE_METRICS=true

# ============================================
# KYC/COMPLIANCE (Optional)
# ============================================

REQUIRE_KYC=false
KYC_LEVEL_1_LIMIT=1000
KYC_LEVEL_2_LIMIT=10000
AML_CHECK_ENABLED=false
SANCTIONS_CHECK_ENABLED=false

# ============================================
# RENDER-SPECIFIC NOTES
# ============================================
# 1. Set these variables in Render Dashboard > Environment
# 2. Use Render's secret files for sensitive data
# 3. DATABASE_URL is auto-set if using Render PostgreSQL
# 4. Free tier services spin down after 15 min inactivity
# 5. Consider upgrading to Starter ($7/mo) for production
# ============================================