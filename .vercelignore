# DO NOT ignore the source files - they are needed!
# Only ignore specific items that shouldn't be deployed:

# Backup files
*.bak
*.tmp
*.log

# Environment files (Vercel handles these separately)
.env
.env.local
.env.*

# Version control
.git/
.gitignore

# Development files
.vscode/
.idea/
*.swp
*.swo

# Documentation (except README which might be needed)
*.md
!README.md

# Test files
**/*.test.js
**/*.spec.js
**/__tests__/

# Empty directories that might cause issues
api/routes/.gitkeep
api/routes/