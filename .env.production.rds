# VALIFI PRODUCTION ENVIRONMENT - AWS RDS POSTGRESQL
# =======================================================

# Application Settings
NODE_ENV=production
PORT=8080

# AWS RDS PostgreSQL Database Configuration
# Replace with your actual RDS credentials
DB_HOST=valifi-production-db.c8y4mxfhjklm.us-east-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=valifi_production
DB_USER=valifi_admin
DB_PASSWORD=YOUR_RDS_PASSWORD_HERE

# Connection Pool Settings
DB_POOL_MAX=20
DB_POOL_MIN=5
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=10000
DB_STATEMENT_TIMEOUT=30000

# Alternative DATABASE_URL format (PostgreSQL connection string)
# DATABASE_URL=postgresql://valifi_admin:YOUR_PASSWORD@valifi-production-db.c8y4mxfhjklm.us-east-1.rds.amazonaws.com:5432/valifi_production

# JWT Security
JWT_SECRET=valifi_jwt_production_secret_2025_secure_key_app_runner_rds
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# CORS Configuration
CORS_ORIGIN=*

# Security Headers
HELMET_ENABLED=true

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload Limits
MAX_FILE_SIZE=10485760

# Session Configuration
SESSION_SECRET=valifi_session_secret_production_2025
SESSION_TIMEOUT=3600000

# Email Configuration (for production notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@valifi.com

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Redis Configuration (optional, for caching)
REDIS_URL=
REDIS_TTL=3600

# Monitoring
HEALTH_CHECK_ENABLED=true
METRICS_ENABLED=true

# Feature Flags
ENABLE_REAL_TRADING=false
ENABLE_KYC_VERIFICATION=true
ENABLE_2FA=true
ENABLE_REFERRALS=true

# External API Keys (for production integrations)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
COINBASE_API_KEY=
COINBASE_SECRET_KEY=
STRIPE_SECRET_KEY=
PLAID_CLIENT_ID=
PLAID_SECRET=

# Bot Configuration
BOT_EXECUTION_TIMEOUT=30000
MAX_CONCURRENT_BOTS=10
BOT_HEARTBEAT_INTERVAL=60000

# =======================================================
# IMPORTANT: Update DB_PASSWORD with your actual RDS password
# IMPORTANT: Update all API keys before production deployment
# =======================================================