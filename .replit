modules = ["php-8.2", "nodejs-20"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[deployment]
deploymentTarget = "autoscale"
run = ["next", "start"]
build = ["next", "build"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Valifi Full-Stack Kingdom"

[[workflows.workflow]]
name = "Valifi Full-Stack Kingdom"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run full-stack"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 42537
externalPort = 3000
